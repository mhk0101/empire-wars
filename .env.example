# ============================================================
# این فایل را کپی کن و اسمش را به ".env" تغییر بده
# سپس مقادیر را با اطلاعات خودت پر کن.
# ============================================================

# --- دیتابیس (الزامی) ---
# ساختار: postgresql://کاربر:رمز@127.0.0.1:5432/نام_دیتابیس
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# --- ربات تلگرام (اختیاری — اگر می‌خواهی ربات وصل شود) ---
# توکن را از @BotFather در تلگرام بگیر (دستور /newbot)
TELEGRAM_BOT_TOKEN=8055199564:AAGEmDf9_r_wMogN39kJuYYP6KfJ6cf575s

# آدرس کامل سایت با https (برای دکمه «ورود به بازی» داخل ربات)
# مثال: https://yourgame.vercel.app
# روی سیستم محلی، ربات کار نمی‌کند چون تلگرام به https نیاز دارد.
NEXT_PUBLIC_APP_URL=https://empire-wars-2y2m.vercel.app/

# یک رمز دلخواه برای امنیت webhook (هر چیزی می‌توانی بگذاری)
TELEGRAM_WEBHOOK_SECRET=mysecret123
